{
  "functions": {
    "api/drive.js": {
      "memory": 256,
      "maxDuration": 10
    },
    "api/import.js": {
      "memory": 1024,
      "maxDuration": 60
    },
    "api/analyze.js": {
      "memory": 512,
      "maxDuration": 30
    },
    "api/conciliate.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/).*)",
      "destination": "/index.html"
    }
  ]
}
